# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored.

# OAuth 2.0 Client ID of type "Desktop app" from Google Cloud Console
# → APIs & Services → Credentials. Used by the Wails desktop build to
# run the PKCE sign-in flow.
GOOGLE_OAUTH_CLIENT_ID=

# Client secret shown next to the Desktop-app client ID in Google Cloud
# Console. Despite the name, this value is not considered secret for
# installed apps — Google documents it as embedded in the binary:
#   https://developers.google.com/identity/protocols/oauth2/native-app
# Google's token endpoint nevertheless requires it for this client
# type, so the desktop flow sends it alongside the PKCE verifier.
GOOGLE_OAUTH_CLIENT_SECRET=
