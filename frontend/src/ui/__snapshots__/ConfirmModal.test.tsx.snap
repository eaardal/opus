// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ConfirmHost + confirm() > matches snapshot for a typical destructive confirm 1`] = `
<div
  class="confirm-overlay"
>
  <div
    aria-describedby="confirm-message"
