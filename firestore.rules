rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Email allowlist — must stay in sync with the client-side check in
    // services/firebase/authService.ts. Comparison is lowercased; matches()
    // is a full-string match so .* at the start is required.
    function isAllowedUser() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && (
               request.auth.token.email.lower() == 'eirikaardal@gmail.com'
               || request.auth.token.email.lower().matches('.*@tv2[.]no')
               || request.auth.token.email.lower().matches('.*@apparat[.]no')
             );
    }

    // Per-user profile docs, written on sign-in. Any allowed user can read the
    // directory (owners need it to find people to invite to a workspace);
    // writes are only permitted to one's own document and the email must
    // match the auth token to keep the directory honest.
    match /users/{userId} {
      allow read: if isAllowedUser();
      allow create, update: if isAllowedUser()
                            && request.auth.uid == userId
                            && request.resource.data.uid == userId
                            && request.resource.data.email == request.auth.token.email;
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      // Read predicates are written so each branch matches one of the queries
      // listMine() runs (`memberIds array-contains uid` and `ownerId == uid`).
      // Firestore's query-time rule analysis must be able to map each clause
      // onto a query filter, otherwise it rejects the list with "Missing or
      // insufficient permissions" — so we keep predicates flat and avoid
      // helper-function indirection on the read rule.

      // For any operation that mutates state, treat workspaces with a
      // `memberIds` array as fully role-managed; pre-roles workspaces with
      // only `ownerId` give the original creator owner-equivalent access
      // until the first invite triggers the lazy upgrade.
      function memberRole() {
        return resource.data.members[request.auth.uid].role;
      }
      function isLegacyOwner() {
        return !('memberIds' in resource.data)
            && resource.data.ownerId == request.auth.uid;
      }
      function isOwner() {
        return isLegacyOwner()
            || ('memberIds' in resource.data
                && request.auth.uid in resource.data.memberIds
                && memberRole() == 'owner');
      }
      function canEditContent() {
        return isLegacyOwner()
            || ('memberIds' in resource.data
                && request.auth.uid in resource.data.memberIds
                && (memberRole() == 'owner' || memberRole() == 'editor'));
      }
      function editorAllowedKeys() {
        return ['projects', 'people', 'teams', 'name', 'updatedAt'];
      }
      function ownerAllowedKeys() {
        return ['projects', 'people', 'teams', 'name', 'updatedAt', 'members', 'memberIds'];
      }
      function changedKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }

      // Create: must claim self as owner in all three places.
      allow create: if isAllowedUser()
                    && request.resource.data.ownerId == request.auth.uid
                    && request.auth.uid in request.resource.data.memberIds
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.members[request.auth.uid].role == 'owner';

      // Read: anyone whose uid is in memberIds OR who is named on ownerId.
      // The ownerId clause covers (a) legacy pre-roles workspaces and
      // (b) the original creator after they've been removed from members,
      // who can still browse the workspace they made. Editing/deleting in
      // case (b) is still gated on members below.
      // Note: memberIds presence is checked first; without the guard,
      // accessing a missing field can fail rule evaluation.
      allow read: if isAllowedUser() && (
        ('memberIds' in resource.data && request.auth.uid in resource.data.memberIds)
        || resource.data.ownerId == request.auth.uid
      );

      // Update: editors → content fields; owners → content + members/memberIds.
      // ownerId is frozen after create — transfer ownership via members.{uid}.role.
      allow update: if isAllowedUser() && (
        (canEditContent() && changedKeys().hasOnly(editorAllowedKeys()))
        || (isOwner() && changedKeys().hasOnly(ownerAllowedKeys()))
      );

      // Delete: owners only.
      allow delete: if isAllowedUser() && isOwner();
    }

    // Default deny for anything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
