rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Email allowlist — must stay in sync with the client-side check in
    // services/firebase/authService.ts. Comparison is lowercased; matches()
    // is a full-string match so .* at the start is required.
    function isAllowedUser() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && (
               request.auth.token.email.lower() == 'eirikaardal@gmail.com'
               || request.auth.token.email.lower().matches('.*@tv2[.]no')
               || request.auth.token.email.lower().matches('.*@apparat[.]no')
             );
    }

    // Per-user profile docs, written on sign-in. Document ID is the user's
    // email address — stable across Firebase projects. Any allowed user can
    // read the directory; writes are only permitted to one's own document
    // and the email must match the document ID to keep the directory honest.
    match /users/{userEmail} {
      allow read: if isAllowedUser();
      allow create, update: if isAllowedUser()
                            && request.auth.token.email == userEmail
                            && request.resource.data.email == request.auth.token.email;
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      // ── Workspace-root helpers ────────────────────────────────────────────────
      // These operate on resource.data, which refers to the workspace document
      // when evaluated in the root match block. Do NOT call from subcollection
      // rules — use the ws* helpers below instead.

      function memberRole() {
        return resource.data.members[request.auth.token.email].role;
      }
      function isLegacyOwner() {
        return !('memberIds' in resource.data)
            && resource.data.ownerId == request.auth.token.email;
      }
      function isOwner() {
        return isLegacyOwner()
            || ('memberIds' in resource.data
                && request.auth.token.email in resource.data.memberIds
                && memberRole() == 'owner');
      }
      function canEditContent() {
        return isLegacyOwner()
            || ('memberIds' in resource.data
                && request.auth.token.email in resource.data.memberIds
                && (memberRole() == 'owner' || memberRole() == 'editor'));
      }
      function changedKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }
      // projects/people/teams are subcollections — they are not fields on the
      // workspace root document and must not appear in update payloads.
      function editorAllowedKeys() {
        return ['name', 'updatedAt'];
      }
      function ownerAllowedKeys() {
        return ['name', 'updatedAt', 'members', 'memberIds'];
      }

      // ── Subcollection helpers ─────────────────────────────────────────────────
      // In a subcollection match block, resource.data is the subcollection
      // document, not the workspace. These helpers fetch the workspace via get()
      // so subcollection rules can check workspace-level membership correctly.

      function wsData() {
        return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
      }
      function wsCanRead() {
        let w = wsData();
        return ('memberIds' in w && request.auth.token.email in w.memberIds)
            || w.ownerId == request.auth.token.email;
      }
      function wsCanEdit() {
        let w = wsData();
        return (!('memberIds' in w) && w.ownerId == request.auth.token.email)
            || ('memberIds' in w
                && request.auth.token.email in w.memberIds
                && (w.members[request.auth.token.email].role == 'owner'
                    || w.members[request.auth.token.email].role == 'editor'));
      }

      // Create: must claim self as owner in all three places.
      allow create: if isAllowedUser()
                    && request.resource.data.ownerId == request.auth.token.email
                    && request.auth.token.email in request.resource.data.memberIds
                    && request.auth.token.email in request.resource.data.members
                    && request.resource.data.members[request.auth.token.email].role == 'owner';

      // Read: anyone whose email is in memberIds OR who is named on ownerId.
      // The ownerId clause covers (a) legacy pre-roles workspaces and
      // (b) the original creator after they've been removed from members,
      // who can still browse the workspace they made.
      allow read: if isAllowedUser() && (
        ('memberIds' in resource.data && request.auth.token.email in resource.data.memberIds)
        || resource.data.ownerId == request.auth.token.email
      );

      // Update: editors → name/updatedAt; owners → name/updatedAt/members/memberIds.
      // ownerId is frozen after create — transfer ownership via members.{email}.role.
      allow update: if isAllowedUser() && (
        (canEditContent() && changedKeys().hasOnly(editorAllowedKeys()))
        || (isOwner() && changedKeys().hasOnly(ownerAllowedKeys()))
      );

      // Delete: owners only.
      allow delete: if isAllowedUser() && isOwner();

      // ── Projects subcollection ────────────────────────────────────────────────
      match /projects/{projectId} {
        allow get, list: if isAllowedUser() && wsCanRead();
        allow create, update, delete: if isAllowedUser() && wsCanEdit();

        // ── Tasks subcollection ────────────────────────────────────────────────
        match /tasks/{taskId} {
          allow get, list: if isAllowedUser() && wsCanRead();
          allow create, update, delete: if isAllowedUser() && wsCanEdit();
        }

        // ── Groups subcollection ───────────────────────────────────────────────
        match /groups/{groupId} {
          allow get, list: if isAllowedUser() && wsCanRead();
          allow create, update, delete: if isAllowedUser() && wsCanEdit();
        }
      }

      // ── People subcollection ──────────────────────────────────────────────────
      match /people/{personId} {
        allow get, list: if isAllowedUser() && wsCanRead();
        allow create, update, delete: if isAllowedUser() && wsCanEdit();
      }

      // ── Teams subcollection ───────────────────────────────────────────────────
      match /teams/{teamId} {
        allow get, list: if isAllowedUser() && wsCanRead();
        allow create, update, delete: if isAllowedUser() && wsCanEdit();
      }
    }

    // Default deny for anything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
